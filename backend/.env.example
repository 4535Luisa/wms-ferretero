# Puerto del servidor
PORT=3000

# Supabase
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<anon-key-publica>
# Clave privada con privilegios de servicio: NUNCA exponer en frontend ni commitear
SUPABASE_SERVICE_KEY=<service-role-key>

# CORS (opcional). Orígenes exactos permitidos, separados por coma:
# CORS_ORIGINS=https://mi-sitio.com,https://app.mi-sitio.com
# Nombre del sitio Netlify para permitir SOLO ese sitio + sus previews
# (sin esto, se permite cualquier *.netlify.app — modo permisivo de respaldo):
# NETLIFY_SITE=mi-sitio-netlify
